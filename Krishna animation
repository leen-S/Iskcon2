// ═══════════════════════════════════════════════════════════════
//  ANIMATION CONSTANTS
// ═══════════════════════════════════════════════════════════════

// Layer 1 — body horizontal sway
//   Amplitude 2.2 px keeps the integer steps sparse (fewer snaps per cycle)
//   vs 2.5 which steps more often and feels less smooth.
static const float BODY_AMP    = 2.2f;   // peak px
static const float BODY_PERIOD = 3.2f;   // seconds

// Layer 2 — feather micro-sway
//   Blended as an additive leverage multiplier, NOT a separate integer step.
//   Net feather amp = BODY_AMP + FEATHER_EXTRA at the very tip.
//   Single lroundf() at the end → no independent feather snapping.
static const float FEATHER_EXTRA  = 0.6f;  // extra px amplitude at tip only
static const float FEATHER_PERIOD = 2.1f;
static const int   FEATHER_ROWS   = 8;     // rows from tip that blend the extra

// Layer 3 — flute sparkle
static const int   FLUTE_ROW     = 26;
static const float SHIMMER_PERIOD = 0.9f;
static const float SHIMMER_THRESH = 0.6f;  // raised slightly → shorter duty

// Layout on 64×128 canvas
static const int BASE_X = (CANVAS_W - BMP_W) / 2;  // 12
static const int BASE_Y = (CANVAS_H - BMP_H) / 2;  // 10

#ifndef TWO_PI
  #define TWO_PI 6.28318530718f
#endif

// ═══════════════════════════════════════════════════════════════
//  ANIMATION STATE
// ═══════════════════════════════════════════════════════════════
static float    bodyPhase    = 0.0f;
static float    featherPhase = 0.94f;  // natural counter-phase pre-seed
static float    shimmerPhase = 0.0f;
static uint32_t prevFrameUs  = 0;

// ═══════════════════════════════════════════════════════════════
//  RENDERING
// ═══════════════════════════════════════════════════════════════

/**
 * Draw one PROGMEM bitmap row at display position (originX + xShift, rowY).
 * Unsigned cast on bounds checks: single compare covers both <0 and >=limit.
 */
static inline void drawRow(int originX, int rowY, int row, int xShift) {
  if ((unsigned)rowY >= (unsigned)CANVAS_H) return;
  const int x0 = originX + xShift;
  for (int col = 0; col < BMP_W; col++) {
    if (pgm_read_byte(&krishna_bmp[row][col >> 3]) & (0x80 >> (col & 7))) {
      const unsigned px = (unsigned)(x0 + col);
      if (px < (unsigned)CANVAS_W)
        oled.drawPixel((int)px, rowY, SSD1306_WHITE);
    }
  }
}

/**
 * Render full frame.
 *
 * bodySin    — sinf(bodyPhase),    pre-computed
 * featherSin — sinf(featherPhase), pre-computed
 * shimmerOn  — true → draw sparkle at flute tip
 */
static void renderKrishna(float bodySin, float featherSin, bool shimmerOn) {
  oled.clearDisplay();

  // Pre-compute the per-row reciprocal once
  const float invBmpH1 = 1.0f / (float)(BMP_H - 1);

  for (int row = 0; row < BMP_H; row++) {
    // Leverage: 1.0 at tip → 0.0 at base  (pivot-at-foot model)
    const float lev = 1.0f - (float)row * invBmpH1;

    // Base contribution from body sway
    float sway = bodySin * BODY_AMP * lev;

    // Feather rows: blend in extra micro-sway additively in float space
    // — avoids a separate integer snap
    if (row < FEATHER_ROWS) {
      const float fBlend = 1.0f - (float)row * (1.0f / (float)FEATHER_ROWS);
      sway += featherSin * FEATHER_EXTRA * fBlend;
    }

    // ONE clean integer round at the very end — no truncation asymmetry,
    // no per-frame dithering (those were the stutter sources in v3.0).
    const int xShift = (int)lroundf(sway);

    drawRow(BASE_X, BASE_Y + row, row, xShift);
  }

  // Flute-tip sparkle
  if (shimmerOn) {
    const float lev  = 1.0f - (float)FLUTE_ROW * invBmpH1;
    const int   sOff = (int)lroundf(bodySin * BODY_AMP * lev);
    const int   spkX = BASE_X + sOff - 2;
    const int   spkY = BASE_Y + FLUTE_ROW;
    if ((unsigned)spkY < (unsigned)CANVAS_H) {
      if ((unsigned)spkX       < (unsigned)CANVAS_W) oled.drawPixel(spkX,     spkY,     SSD1306_WHITE);
      if ((unsigned)(spkX + 1) < (unsigned)CANVAS_W) oled.drawPixel(spkX + 1, spkY,     SSD1306_WHITE);
      if ((unsigned)spkY + 1   < (unsigned)CANVAS_H) oled.drawPixel(spkX,     spkY + 1, SSD1306_WHITE);
    }
  }

  // Push to display immediately — minimises blank-screen gap
  oled.display();
}

// ═══════════════════════════════════════════════════════════════
//  SETUP
// ═══════════════════════════════════════════════════════════════
void setup() {
  Wire.begin(21, 22);
  Wire.setClock(I2C_FREQ);   // 400 kHz — essential, unlocks ~50 FPS

  if (!oled.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    for (;;) delay(1000);    // halt silently on init failure
  }

  // Portrait: 128-px long axis becomes vertical.
  // Swap to setRotation(3) if figure appears upside-down.
  oled.setRotation(1);
  oled.clearDisplay();
  oled.display();
  delay(80);

  prevFrameUs = micros();
}

// ═══════════════════════════════════════════════════════════════
//  LOOP — time-based, spin-wait, no delay(), delta-independent
// ═══════════════════════════════════════════════════════════════
void loop() {
  const uint32_t now     = micros();
  const uint32_t elapsed = now - prevFrameUs;
  if (elapsed < FRAME_US) return;   // spin — tightest possible frame gate
  prevFrameUs = now;

  // Delta time in seconds, capped at 3× target frame to absorb I²C stalls
  float dt = (float)elapsed * 1e-6f;
  const float DT_MAX = (float)FRAME_US * 3e-6f;
  if (dt > DT_MAX) dt = DT_MAX;

  // ── Advance phases (radians per second × dt) ─────────────────────────────
  bodyPhase    += dt * (TWO_PI / BODY_PERIOD);
  featherPhase += dt * (TWO_PI / FEATHER_PERIOD);
  shimmerPhase += dt * (TWO_PI / SHIMMER_PERIOD);

  // Wrap to [0, 2π) — prevents float precision erosion over long sessions
  if (bodyPhase    >= TWO_PI) bodyPhase    -= TWO_PI;
  if (featherPhase >= TWO_PI) featherPhase -= TWO_PI;
  if (shimmerPhase >= TWO_PI) shimmerPhase -= TWO_PI;

  // ── Evaluate ─────────────────────────────────────────────────────────────
  // Compute both sines once — used 107 times each in the render loop
  const float bodySin    = sinf(bodyPhase);
  const float featherSin = sinf(featherPhase);
  const bool  shimmerOn  = (sinf(shimmerPhase) > SHIMMER_THRESH);

  // ── Render ───────────────────────────────────────────────────────────────
  renderKrishna(bodySin, featherSin, shimmerOn);
}
